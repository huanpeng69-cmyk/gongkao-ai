# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/node_modules_old
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/android/**/build/
/android/.gradle/
/android/local.properties
/android/app/src/main/assets/public/
/android/app/src/main/assets/capacitor.config.json
*.apk
*.aab
*.tar.gz

# misc
.DS_Store
*.pem
*.jks
*.keystore
/mobile-check/
/.edge-mobile-check-profile/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.pid
__pycache__/
*.py[cod]

# generated / temporary data
/data/gkzhenti_cache/
/data/*.before-*.json
/data/*.lock
/data/*_report.json
/data/*_unmatched.csv
/data/missing_explanations.csv

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
