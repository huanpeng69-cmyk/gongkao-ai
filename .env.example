PORT=3000

# Server-side AI fallback configuration.
# Leave values empty when using the in-app Settings page.
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_AUTH_SCHEME=bearer

# Optional image generation fallback configuration.
IMAGE_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=
IMAGE_AUTH_SCHEME=bearer
IMAGE_SIZE=1024x1024

# Optional public defaults injected into the browser build.
# Do not put real API keys here before publishing to GitHub.
NEXT_PUBLIC_GONGKAO_AI_NAME=
NEXT_PUBLIC_GONGKAO_AI_BASE=
NEXT_PUBLIC_GONGKAO_AI_KEY=
NEXT_PUBLIC_GONGKAO_AI_AUTH=bearer
NEXT_PUBLIC_GONGKAO_AI_PROTOCOL=openai
NEXT_PUBLIC_GONGKAO_AI_MODEL=
NEXT_PUBLIC_GONGKAO_IMAGE_BASE=
NEXT_PUBLIC_GONGKAO_IMAGE_KEY=
NEXT_PUBLIC_GONGKAO_IMAGE_AUTH=bearer
NEXT_PUBLIC_GONGKAO_IMAGE_MODEL=
NEXT_PUBLIC_GONGKAO_IMAGE_SIZE=1024x1024
